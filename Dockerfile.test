FROM golang:1.26-bookworm AS gobase

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    tmux \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy Go toolchain
COPY --from=gobase /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Copy built solo binary (supports multiple TARGETARCH values)
ARG TARGETARCH=amd64
COPY dist/solo_linux_${TARGETARCH}_*/solo /usr/local/bin/solo
RUN chmod +x /usr/local/bin/solo

# Signal to tests that they're running inside the integration container
ENV SOLO_INTEGRATION=1

WORKDIR /app

# Copy Go module files and download dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy integration test files
COPY test/integration/ ./test/integration/

CMD ["go", "test", "-v", "-tags", "integration", "-count=1", "./test/integration/..."]
